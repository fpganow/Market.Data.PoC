puts "+-------------------------------------------+";
puts "Writing Verilog from dcp";
puts "# of Args $argc";

set dcp_file [lindex $argv 0];
puts [format "DCP: %s" $dcp_file];

set dirname [file dirname $dcp_file];
puts [format "Dir: %s" $dirname];

set rootname [file rootname [file tail $dcp_file]];
puts [format "rootname: %s" $rootname];
puts [format "dirname: %s" $dirname];
set comp [split $rootname "_"];
set comp [lreplace $comp 0 0];
set joined [join $comp "_"];
set synth_file [format "%s/%s.v" $dirname $rootname];
#set synth_file [format "%s/autogenerated_tb_synth_func.v" $dirname];
#set synth_file [format "%s/sim/synth/func/NiFpgaIPWrapper_%s_synth_func.vhd" $dirname $joined];
puts [format "Synth File: %s" $synth_file];

open_checkpoint $dcp_file;
write_verilog -force -file $synth_file;

puts "Done";
puts "+-------------------------------------------+";
