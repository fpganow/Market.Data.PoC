#xsim.dir/autogenerated_tb_synth_func/xsimk: /tools/Xilinx/Vivado/2024.1/lib/lnx64.o/../../tps/lnx64/gcc-9.3.0/bin/../lib64/libstdc++.so.6: version `GLIBCXX_3.4.32' not found (required by /home/john/git/fpganow/Market.Data.PoC/ip_export/sim/libpysv.so)
#xsim.dir/autogenerated_tb_synth_func/xsimk: /tools/Xilinx/Vivado/2024.1/lib/lnx64.o/../../tps/lnx64/gcc-9.3.0/bin/../lib64/libstdc++.so.6: version `GLIBCXX_3.4.29' not found (required by /home/john/git/fpganow/Market.Data.PoC/ip_export/sim/libpysv.so)
#xsim.dir/autogenerated_tb_synth_func/xsimk: /tools/Xilinx/Vivado/2024.1/lib/lnx64.o/../../tps/lnx64/gcc-9.3.0/bin/../lib64/libstdc++.so.6: version `CXXABI_1.3.13' not found (required by /home/john/git/fpganow/Market.Data.PoC/ip_export/sim/libpysv.so)
